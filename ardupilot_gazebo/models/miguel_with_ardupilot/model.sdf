<?xml version="1.0"?>
<sdf version="1.9">
  <model name="miguel_with_ardupilot">


    <plugin name="ArduPilotPlugin" filename="ArduPilotPlugin">
      <!-- Port settings -->
      <fdm_addr>127.0.0.1</fdm_addr>
      <fdm_port_in>9002</fdm_port_in>
      <connectionTimeoutMaxCount>5</connectionTimeoutMaxCount>
      <lock_step>1</lock_step>

      <modelXYZToAirplaneXForwardZDown degrees="true">0 0 0 180 0 0</modelXYZToAirplaneXForwardZDown>
      <gazeboXYZToNED degrees="true">0 0 0 180 0 90</gazeboXYZToNED>

      <!--
          incoming control command [0, 1]
          so offset it by 0 to get [0, 1]
          and divide max target by 1.
          offset = 0
          multiplier = 838 max rpm / 1 = 838
        -->

      <!-- 
          SERVO3_FUNCTION   70 (Throttle)
          SERVO3_MAX        2000
          SERVO3_MIN        1000
          SERVO3_REVERSED   0
          SERVO3_TRIM       1000
       -->
        <control channel="2">
          <jointName>rotor_pusher_joint</jointName>
          <type>VELOCITY</type>
          <useForce>1</useForce>
          <multiplier>800</multiplier>
          <offset>0</offset>
          <servo_min>1000</servo_min>
          <servo_max>2000</servo_max>
        </control>


        <control channel="0">
          <jointName>left_aileron_joint</jointName>
          <type>POSITION</type>
          <useForce>1</useForce>
          <multiplier>1.0</multiplier>
          <offset>-0.5</offset>
          <servo_min>1100</servo_min>
          <servo_max>1900</servo_max>
        </control>


        <control channel="1">
          <jointName>right_aileron_joint</jointName>
          <type>POSITION</type>
          <useForce>1</useForce>
          <multiplier>1.0</multiplier>
          <offset>-0.5</offset>
          <servo_min>1100</servo_min>
          <servo_max>1900</servo_max>
        </control>

        <control channel="3">
          <jointName>elevators_joint</jointName>
          <type>POSITION</type>
          <useForce>1</useForce>
          <multiplier>1.0</multiplier>
          <offset>-0.5</offset>
          <servo_min>1100</servo_min>
          <servo_max>1900</servo_max>
        </control>
        

        <control channel="4">
          <jointName>rudderevators_joint</jointName>
          <type>POSITION</type>
          <useForce>1</useForce>
          <multiplier>1.0</multiplier>
          <offset>-0.5</offset>
          <servo_min>1100</servo_min>
          <servo_max>1900</servo_max>
        </control>

    </plugin>






       <!-- plugins -->
    <plugin filename="gz-sim-joint-state-publisher-system"
      name="gz::sim::systems::JointStatePublisher">
    </plugin>


    <!-- AERODYNAMICS -->


    <!-- rotor_pusher lift-drag -->
    <plugin filename="gz-sim-lift-drag-system"
        name="gz::sim::systems::LiftDrag">
      <a0>0.30</a0>
      <alpha_stall>1.4</alpha_stall>
      <cla>4.2500</cla>
      <cda>0.10</cda>
      <cma>0.0</cma>
      <cla_stall>-0.025</cla_stall>
      <cda_stall>0.0</cda_stall>
      <cma_stall>0.0</cma_stall>
      <area>0.0042815 </area>
      <air_density>1.2041</air_density>
      <cp>0.074205 0 0</cp>
      <forward>1 0 0</forward>
      <upward>0 0 1</upward>
      <link_name>iris_prop_ccw</link_name>
    </plugin>
    <plugin filename="gz-sim-lift-drag-system"
        name="gz::sim::systems::LiftDrag">
      <a0>0.30</a0>
      <alpha_stall>1.4</alpha_stall>
      <cla>4.2500</cla>
      <cda>0.10</cda>
      <cma>0.0</cma>
      <cla_stall>-0.025</cla_stall>
      <cda_stall>0.0</cda_stall>
      <cma_stall>0.0</cma_stall>
      <area>0.0042815 </area>
      <air_density>1.2041</air_density>
      <cp>-0.074205 0 0</cp>
      <forward>-1 0 0</forward>
      <upward>0 0 1</upward>
      <link_name>iris_prop_ccw</link_name>
    </plugin>

  
        <!-- left wing lift-drag -->
    <plugin filename="gz-sim-lift-drag-system"
        name="gz::sim::systems::LiftDrag">
      <a0>0.13</a0>
      <cla>3.7</cla>
      <cda>0.06417112299</cda>
      <cma>0.0</cma>
      <alpha_stall>0.3391428111</alpha_stall>
      <cla_stall>-3.85</cla_stall>
      <cda_stall>-0.9233984055</cda_stall>
      <cma_stall>0.0</cma_stall>
      <cp>-0.025 0.3 0</cp>
      <area>0.192</area>
      <air_density>1.2041</air_density>
      <forward>1 0 0</forward>
      <upward>0 0 1</upward>
      <link_name>body</link_name>
    </plugin>
        <!-- right wing lift-drag -->
    <plugin filename="gz-sim-lift-drag-system"
        name="gz::sim::systems::LiftDrag">
      <a0>0.13</a0>
      <cla>3.7</cla>
      <cda>0.06417112299</cda>
      <cma>0.0</cma>
      <alpha_stall>0.3391428111</alpha_stall>
      <cla_stall>-3.85</cla_stall>
      <cda_stall>-0.9233984055</cda_stall>
      <cma_stall>0.0</cma_stall>
      <cp>-0.025 -0.3 0</cp>
      <area>0.192</area>
      <air_density>1.2041</air_density>
      <forward>1 0 0</forward>
      <upward>0 0 1</upward>
      <link_name>body</link_name>
    </plugin>

    <!-- left aileron lift-drag -->
    <plugin filename="gz-sim-lift-drag-system"
        name="gz::sim::systems::LiftDrag">
      <a0>0.15</a0>
      <cla>3.5</cla>
      <cda>0.06417112299</cda>
      <cma>0.0</cma>
      <alpha_stall>0.6391428111</alpha_stall>
      <cla_stall>-3.85</cla_stall>
      <cda_stall>-0.9233984055</cda_stall>
      <cma_stall>0.0</cma_stall>
      <cp>-0.30 0.75 -0.005</cp>
      <area>0.010</area>
      <air_density>1.2041</air_density>
      <forward>1 0 0</forward>
      <upward>0 0 1</upward>
      <link_name>body</link_name>
      <control_joint_name>left_aileron_joint</control_joint_name>
      <control_joint_rad_to_cl>-2.0</control_joint_rad_to_cl>
    </plugin>
    <!-- right aileron lift-drag --> <!-- right aileron lift-drag -->
    <plugin filename="gz-sim-lift-drag-system"
        name="gz::sim::systems::LiftDrag">
      <a0>0.15</a0>
      <cla>3.5</cla>
      <cda>0.06417112299</cda>
      <cma>0.0</cma>
      <alpha_stall>0.6391428111</alpha_stall>
      <cla_stall>-3.85</cla_stall>
      <cda_stall>-0.9233984055</cda_stall>
      <cma_stall>0.0</cma_stall>
      <cp>-0.30 -0.75 -0.005</cp>
      <area>0.010</area>
      <air_density>1.2041</air_density>
      <forward>1 0 0</forward>
      <upward>0 0 1</upward>
      <link_name>body</link_name>
      <control_joint_name>right_aileron_joint</control_joint_name>
      <control_joint_rad_to_cl>2.0</control_joint_rad_to_cl>
    </plugin>

     <!-- elevators lift-drag -->
        <plugin filename="gz-sim-lift-drag-system"
        name="gz::sim::systems::LiftDrag">
      <a0>0.087</a0>
      <cla>3.5</cla>
      <cda>0.06417112299</cda>
      <cma>0.0</cma>
      <alpha_stall>0.51</alpha_stall>
      <cla_stall>-3.5</cla_stall>
      <cda_stall>-0.9</cda_stall> 
      <cma_stall>0.0</cma_stall>
      <cp>-0.715 0 0.14</cp>
      <area>0.010</area>
      <air_density>1.2041</air_density>
      <forward>1 0 0</forward>
      <upward>0 0 1</upward>
      <link_name>body</link_name>
      <control_joint_name>elevators_joint</control_joint_name>
      <control_joint_rad_to_cl>-2.0</control_joint_rad_to_cl>
    </plugin>



     <!-- Rudder lift-drag -->
       <!-- elevators lift-drag -->
      <plugin filename="gz-sim-lift-drag-system"
       name="gz::sim::systems::LiftDrag">
      <a0>0.087</a0>
      <cla>3.5</cla>
      <cda>0.06417112299</cda>
      <cma>0.0</cma>
      <alpha_stall>0.51</alpha_stall>
      <cla_stall>-3.5</cla_stall>
      <cda_stall>-0.9</cda_stall> 
      <cma_stall>0.0</cma_stall>
      <cp>-0.71 0 0.32</cp>
      <area>0.010</area>
      <air_density>1.2041</air_density>
      <forward>1 0 0</forward>
      <upward>0 1 0</upward>
      <link_name>body</link_name>
      <control_joint_name>rudderevators_joint</control_joint_name>
      <control_joint_rad_to_cl>-1.0</control_joint_rad_to_cl>
    </plugin>




    <static>false</static>
    <pose>0 0 0.5 0 0 0</pose>
    <!-- Main fuselage -->
    <link name="body">
      <pose>0 0 0 0 0 0</pose>

      <visual name="body_visual">
        <geometry>
          <mesh>
            <uri>model://miguel_with_ardupilot/meshes/corpo.dae</uri>
          </mesh>
        </geometry>

        <material>
         <ambient>0 0 1 1</ambient> <!-- Blue -->
         </material>

      </visual>

      <collision name="body_collision">
          <geometry>
          <mesh>
            <uri>model://miguel_with_ardupilot/meshes/body.dae</uri>
          </mesh>
          </geometry>
      </collision>

          <!-- Barometer -->
    
      <sensor name="air_pressure_sensor" type="air_pressure">
        <always_on>true</always_on>
        <update_rate>30</update_rate>
        <plugin name="gz::sim::systems::AirPressure" filename="gz-sim-air-pressure-system"/>
      </sensor>

      <!-- Magnetometer -->
      <sensor name="magnetometer_sensor" type="magnetometer">
        <always_on>true</always_on>
        <update_rate>100</update_rate>
        <plugin name="gz::sim::systems::Magnetometer" filename="gz-sim-magnetometer-system"/>
      </sensor>

      <!-- GPS -->
      <sensor name="navsat_sensor" type="navsat">
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <plugin name="gz::sim::systems::NavSat" filename="gz-sim-navsat-system"/>
      </sensor>

      <!-- IMU -->
      <sensor name="imu_sensor" type="imu">
        <always_on>true</always_on>
        <update_rate>1000</update_rate>
        <plugin name="gz::sim::systems::Imu" filename="gz-sim-imu-system"/>
      </sensor>
      

      <!-- Altimeter -->
      <sensor name="altimeter_sensor" type="altimeter">
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <plugin name="gz::sim::systems::Altimeter" filename="gz-sim-altimeter-system"/>
      </sensor>
       
       <!-- Air_Speed -->

          <!-- ?????? -->


      <inertial>
        <mass>3.3</mass>
        <inertia>
          <ixx>0.170</ixx>
          <ixy>0.0</ixy>
          <ixz>0.019</ixz>
          <iyy>0.289</iyy>
          <iyz>0.0</iyz>
          <izz>0.443</izz>
        </inertia>
      </inertial>
    </link>

    <link name="left_aileron">
      <pose>-0.16 -0.67 0.17 0 0 0</pose>

      <visual name="left_aileron_visual">
          <geometry>
            <mesh>
              <uri>model://miguel_with_ardupilot/meshes/left_aileron.dae</uri>
            </mesh>
          </geometry>

          <material>
            <diffuse>1.0 1.0 1.0</diffuse>
            <specular>1.0 1.0 1.0</specular>
            <pbr>
              <metal>
                  <albedo_map>model://skywalker_x8/materials/textures/blue_metal/blue_metal_normal.jpg</albedo_map>
                  <metalness>0.5</metalness>
              </metal>
            </pbr>
          </material>
      </visual>

      <collision name="left_aileron_collision">
          <geometry>
            <box>
              <size>0.07 0.3 0.05</size>
            </box>
          </geometry>
      </collision>

      <inertial>
          <mass>0.01</mass>
          <inertia>
            <ixx>0.003</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.003</iyy>
            <iyz>0</iyz>
            <izz>0.003</izz>
          </inertia>
       </inertial>
   </link>

    <joint name="left_aileron_joint" type="revolute">
      <parent>body</parent>
      <child>left_aileron</child>

      <pose>0.013 0 0 0 0 0</pose>

      <axis>
        <xyz>0 1 0</xyz> <!-- eixo de rotação, ajustar conforme o modelo -->
        <limit>
          <lower>-0.5</lower>   <!-- cerca de -30° -->
          <upper>0.5</upper>    <!-- cerca de +30° -->
        </limit>
      </axis>
    </joint>

   <link name="right_aileron">
      <pose>-0.16 0.67 0.17 0 0 0</pose>

      <visual name="right_aileron_visual">
          <geometry>
            <mesh>
              <uri>model://miguel_with_ardupilot/meshes/left_aileron.dae</uri>
            </mesh>
          </geometry>

        <material>
          <diffuse>1.0 1.0 1.0</diffuse>
          <specular>1.0 1.0 1.0</specular>
          <pbr>
            <metal>
                <albedo_map>model://skywalker_x8/materials/textures/blue_metal/blue_metal_normal.jpg</albedo_map>
                <metalness>0.5</metalness>
            </metal>
          </pbr>
        </material>
      </visual>

      <collision name="right_aileron_collision">
          <geometry>
            <box>
              <size>0.07 0.3 0.05</size>
            </box>
          </geometry>
      </collision>

        <inertial>
          <mass>0.01</mass>
          <inertia>
            <ixx>0.003</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.003</iyy>
            <iyz>0</iyz>
            <izz>0.003</izz>
          </inertia>
        </inertial>
    </link>

    <joint name="right_aileron_joint" type="revolute">
      <parent>body</parent>
      <child>right_aileron</child>

      <pose>0.013 0 0 0 0 0</pose>

      <axis>
        <xyz>0 1 0</xyz> <!-- eixo de rotação, ajustar conforme o modelo-->
        <limit>
          <lower>-0.5</lower>   <!-- cerca de -30° -->
          <upper>0.5</upper>    <!-- cerca de +30° -->
        </limit>
      </axis>
    </joint>
    
    <link name="iris_prop_ccw">
      <pose>0.512 0 0.12 0 1.5707963267949 0</pose>

      <visual name="iris_prop_ccw_visual">
          <geometry>
            <mesh>
              <uri>model://miguel_with_ardupilot/meshes/iris_prop_ccw.dae</uri>
            </mesh>
          </geometry>

        <material>
          <diffuse>1.0 1.0 1.0</diffuse>
          <specular>1.0 1.0 1.0</specular>
          <pbr>
            <metal>
                <albedo_map>model://skywalker_x8/materials/textures/blue_metal/blue_metal_basecolor.jpg</albedo_map>
                <metalness>0.5</metalness>
            </metal>
          </pbr>
        </material>
     </visual>

      <collision name="iris_prop_ccw_collision">
          <geometry>
            <box>
              <size>0.265 0.03 0.02</size>
            </box>
          </geometry>
      </collision>

      <inertial>
          <mass>0.01</mass>
          <inertia>
            <ixx>0.003</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.003</iyy>
            <iyz>0</iyz>
            <izz>0.003</izz>
          </inertia>
      </inertial>
    </link>

    <joint name='rotor_pusher_joint' type='revolute'>
      <parent>body</parent>
      <child>iris_prop_ccw</child>
      <pose>-0.004 0 0 0 0 0</pose>

      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
        <dynamics>
          <damping>0.002</damping>
        </dynamics>
      </axis>
    </joint>

    <link name="elevators">
      <pose>-0.715 0 0.14 0 0 0</pose>
      <visual name="elevators_visual">
          <geometry>
            <mesh>
              <uri>model://miguel_with_ardupilot/meshes/elevators.dae</uri>
            </mesh>
          </geometry>

        <material>
          <diffuse>1.0 1.0 1.0</diffuse>
          <specular>1.0 1.0 1.0</specular>
          <pbr>
            <metal>
                <albedo_map>model://skywalker_x8/materials/textures/blue_metal/blue_metal_normal.jpg</albedo_map>
                <metalness>0.5</metalness>
            </metal>
          </pbr>
        </material>
     </visual>

      <collision name="elevators_collision">
          <geometry>
            <box>
              <size>0.05 0.6 0.015</size>
            </box>
          </geometry>
      </collision>

        <inertial>
          <mass>0.01</mass>
          <inertia>
            <ixx>0.003</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.003</iyy>
            <iyz>0</iyz>
            <izz>0.003</izz>
          </inertia>
        </inertial>
    </link>
    
     <joint name="elevators_joint" type="revolute">
      <parent>body</parent>
      <child>elevators</child>

      <pose>0.015 0 0 0 0 0</pose>

      <axis>
        <xyz>0 1 0</xyz> <!-- eixo de rotação, ajustar conforme o modelo-->
        <limit>
          <lower>-0.5</lower>   <!-- cerca de -30° -->
          <upper>0.5</upper>    <!-- cerca de +30° -->
        </limit>
      </axis>
    </joint>
    
    
    <link name="rudder">
      <pose>-0.7 0 0.3035 0 0 0</pose>
      <visual name="rudder_visual">
          <geometry>
            <mesh>
              <uri>model://miguel_with_ardupilot/meshes/rudder.dae</uri>
            </mesh>
          </geometry>

        <material>
          <diffuse>1.0 1.0 1.0</diffuse>
          <specular>1.0 1.0 1.0</specular>
          <pbr>
            <metal>
                <albedo_map>model://skywalker_x8/materials/textures/blue_metal/blue_metal_normal.jpg</albedo_map>
                <metalness>0.5</metalness>
            </metal>
          </pbr>
        </material>
     </visual>

      <collision name="rudder_collision">
          <geometry>
            <box>
              <size>0.09 0.03 0.24</size>
            </box>
          </geometry>
      </collision>

        <inertial>
          <mass>0.01</mass>
          <inertia>
            <ixx>0.003</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.003</iyy>
            <iyz>0</iyz>
            <izz>0.003</izz>
          </inertia>
        </inertial>
    </link>

    <joint name="rudderevators_joint" type="revolute">
          <parent>body</parent>
          <child>rudder</child>

          <pose>0.021 0 0 0 0 0</pose>

          <axis>
            <xyz>0 0 1</xyz> <!-- eixo de rotação, ajustar conforme o modelo-->
            <limit>
              <lower>-0.5</lower>   <!-- cerca de -30° -->
              <upper>0.5</upper>    <!-- cerca de +30° -->
            </limit>
          </axis>
    </joint>

  </model>
</sdf>
