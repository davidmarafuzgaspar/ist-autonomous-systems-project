<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="atlas_24_25">
    <static>false</static>  <!-- MUDAR PARA false-->
    <pose>0 0 0 0 0 0</pose>

    <!-- CORPO -->
    <link name="corpo">
      <inertial>
        <pose>1.352 0.475 1.498 0 0 0</pose> <!--isto muda o cg do aviao supostamente--> <!-- este ponto seria o medio entre as posicoes dos links da hinge dos ailerons esquerdo e direito-->
        <mass>17.748</mass>
        <inertia>
          <ixx>4.89725</ixx><ixy>0</ixy><ixz>-0.46934</ixz>
          <iyy>1.88381</iyy><iyz>0</iyz><izz>3.44073</izz>
        </inertia>
      </inertial>
      <visual name="corpo_visual">
        <geometry><mesh><uri>model://atlas_24_25/meshes/abiaum_control2.dae</uri><scale>0.001 0.001 0.001</scale></mesh></geometry>
        <material>
          <ambient>1 0.5 0 1</ambient>   <!--laranja-->
          <diffuse>1 0.5 0 1</diffuse>
        </material>
      </visual>
      <!--para debug-->
      <!-- <visual name="cp_main_wing"> 
        <pose>1.35221 0.46 1.4725 0 0 0</pose>
        <geometry>
          <sphere>
            <radius>0.25</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0 0 1</ambient>
          <diffuse>0 0 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual> -->
      <collision name="corpo_collision">
        <pose>1 1 1 0 0 0</pose>  <!-- pose and axis correspondance   [1 1 1 = EIXO VERMELHO, EIXO AZUL, EIXO VERDE] -->
        <geometry>
          <box>
            <size>2 2 2</size>     
          </box>
        </geometry>
        <!-- <geometry><mesh><uri>model://atlas_24_25/meshes/abiaum_control3.dae</uri><scale>0.001 0.001 0.001</scale></mesh></geometry> -->
      </collision>


      <!-- Sensores -->
      <sensor name="imu_sensor" type="imu">
        <always_on>true</always_on>
        <update_rate>100.0</update_rate>
        <pose>0 0 0 1.5708 0 0</pose>
        <visualize>true</visualize>
      </sensor>

      <sensor name="gps_sensor" type="navsat">
        <always_on>true</always_on>
        <update_rate>10.0</update_rate>
      </sensor>

      <sensor name="magnetometer" type="magnetometer">
        <always_on>true</always_on>
        <!-- <pose>0 0 0 1.5708 0 0</pose>   match IMU  This may fix the mag field issue after deleting the parameter in param file to neglect it-->
      </sensor> 

      <sensor name="barometer" type="air_pressure">
        <always_on>true</always_on>
      </sensor>

      <sensor name="airspeed" type="air_speed">
        <always_on>true</always_on>
      </sensor> 

      <sensor name="altimeter" type="altimeter">
        <always_on>true</always_on>
      </sensor>

    </link>

    <!-- SUPERFÍCIES DE CONTROLO -->
    <!-- AILERON ESQUERDO -->
    <link name="left_aileron">
      <pose>0 0 0 0 0 0</pose> <!--<pose>2.58 0.47 1.695 -1.5 1.555 0.08</pose>-->
