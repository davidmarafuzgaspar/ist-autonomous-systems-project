    <!--Include gimbal-->
    <include merge="true">
      <uri>package://ardupilot_gazebo/models/gimbal_small_3d</uri>
      <name>gimbal</name>
      <pose degrees="true">1.35221 0.165 1.6 0 0 0</pose> <!--AJUSTAR POSE, principalmente em y (altura)-->
    </include>  

    <!-- JOINTS -->

    <joint name="joint_left_aileron_fixed" type="fixed">
      <!-- <pose>0 0 0 0 0 0</pose> --> <!-- o que estava era isto: <pose>0 0 0 -1.5 1.555 0.08</pose> --> <!-- As joints não precisam de pose porque já se diz o child e o parent-->
      <parent>left_aileron_hinge</parent> 
      <child>left_aileron</child> 
    </joint>

    <!-- Hinge Joint -->
    <joint name="joint_left_aileron_hinge" type="revolute">
      <!-- <pose>2.58 0.47 1.695 0 0 0</pose> -->  <!-- posição do hinge no frame do model --> <!-- As joints não precisam de pose porque já se diz o child e o parent-->
      <parent>corpo</parent>
      <child>left_aileron_hinge</child>
      <axis>
        <xyz>1 0 0</xyz>   <!-- ajusta se o eixo real for outro -->
        <limit>
          <lower>-0.39267</lower>
          <upper>0.48</upper> <!-- Subtrair aos limites o angulo de ataque de trim --> <!-- Talvez ao contrário por causa dos sinais (caso o avião voe ao contrário para a esquerda e para a direita)-->
          <effort>8.0</effort> <!-- Nm de torque máximo que esta joint pode aplicar 5-10 valor comum para avião médio-->
        </limit>
        <dynamics>
          <damping>0.6</damping>
          <friction>0.0</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="joint_right_aileron_fixed" type="fixed">
      <parent>right_aileron_hinge</parent> 
      <child>right_aileron</child> 
    </joint>

    <!-- Hinge Joint -->
    <joint name="joint_right_aileron_hinge" type="revolute">
      <parent>corpo</parent>
      <child>right_aileron_hinge</child>
      <axis>
        <xyz>1 0 0</xyz>  
        <limit>
          <lower>-0.39267</lower>
          <upper>0.48</upper>
          <effort>8.0</effort> <!-- Nm de torque máximo que esta joint pode aplicar 5-10 valor comum para avião médio-->
        </limit>
        <dynamics>
          <damping>0.6</damping>
          <friction>0.0</friction>
        </dynamics>
      </axis>
    </joint>

    <!-- <joint name="joint_right_aileron" type="revolute">
      <parent>corpo</parent><child>right_aileron</child>
      <axis><xyz>0 1 0</xyz><limit><lower>-0.2</lower><upper>0.2</upper></limit></axis>
    </joint> -->
