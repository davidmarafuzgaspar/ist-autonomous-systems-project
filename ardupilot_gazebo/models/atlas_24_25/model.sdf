        <geometry><mesh><uri>model://atlas_24_25/meshes/aileron_esquerdo.dae</uri><scale>0.001 0.001 0.001</scale></mesh></geometry>
        <!-- <geometry><box><size>0.6 0.06 0.06</size></box></geometry>  Ajustado ao tamanho do aileron -->
      </collision>
    </link>

