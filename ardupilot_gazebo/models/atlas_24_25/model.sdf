      <cma_stall>0.0</cma_stall>
      <area>0.008</area>
      <air_density>1.2041</air_density>
      <cp>0 0 0.267</cp>   <!--<cp>0 0 0.267</cp>--> <!--<cp>0 0 0.05</cp> (ESTE VALOR É PARA TODOS OS CP DA FRENTE)--> <!-- CP É LOCAL PARA OS ROTORES E VOU PÔ-LO COM O RAIO DAS HÉLICES EM Z (OU SEJA PARA A FRENTE NUMA E PARA TRÁS NOUTRA) -->
