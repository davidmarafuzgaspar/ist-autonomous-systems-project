    </joint> -->
    <!-- <joint name="joint_right_elevator" type="revolute">
      <parent>corpo</parent><child>right_elevator</child>
      <axis><xyz>0 -0.70711 0.70711</xyz><limit><lower>-0.2</lower><upper>0.2</upper></limit></axis>  os eixos têm de estar normalizados
    </joint> -->

    <joint name="joint_left_elevator_fixed" type="fixed">
      <parent>left_elevator_hinge</parent> 
      <child>left_elevator</child> 
    </joint>

    <!-- Hinge Joint -->
    <joint name="joint_left_elevator_hinge" type="revolute">
      <parent>corpo</parent>
      <child>left_elevator_hinge</child>
      <axis>
        <xyz>0 0 1</xyz>  
        <limit>
          <lower>-0.436</lower> 
          <upper>0.436</upper>
          <effort>8.0</effort>
        </limit>
        <dynamics>
          <damping>0.6</damping>
          <friction>0.0</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="joint_right_elevator_fixed" type="fixed">
      <parent>right_elevator_hinge</parent> 
      <child>right_elevator</child> 
    </joint>

    <!-- Hinge Joint -->
    <joint name="joint_right_elevator_hinge" type="revolute">
      <parent>corpo</parent>
      <child>right_elevator_hinge</child>
      <axis>
        <xyz>0 0 1</xyz>  
        <limit>
          <lower>-0.436</lower> 
          <upper>0.436</upper>
          <effort>8.0</effort>
        </limit>
        <dynamics>
          <damping>0.6</damping>
          <friction>0.0</friction>
        </dynamics>
      </axis>
    </joint>


    <joint name="joint_propeller_1" type="revolute">
      <parent>corpo</parent><child>front_left_propeller</child>
      <axis><xyz>0 1 0</xyz><limit><effort>1.485</effort><velocity>602</velocity><lower>-1e16</lower><upper>1e16</upper></limit><dynamics><damping>0.004</damping></dynamics><use_parent_model_frame>1</use_parent_model_frame></axis> <!--Dá para adicionar torque (effort) máximo e valocidade de rotação máxima (rad/s) nos motores-->
    </joint>
    <joint name="joint_propeller_2" type="revolute">
      <parent>corpo</parent><child>front_right_propeller</child>
      <axis><xyz>0 -1 0</xyz><limit><effort>1.485</effort><velocity>602</velocity><lower>-1e16</lower><upper>1e16</upper></limit><dynamics><damping>0.004</damping></dynamics><use_parent_model_frame>1</use_parent_model_frame></axis>
    </joint>
    <joint name="joint_propeller_3" type="revolute">
      <parent>corpo</parent><child>back_left_propeller</child>
      <axis><xyz>0 -1 0</xyz><limit><effort>1.485</effort><velocity>602</velocity><lower>-1e16</lower><upper>1e16</upper></limit><dynamics><damping>0.004</damping></dynamics><use_parent_model_frame>1</use_parent_model_frame></axis>
    </joint>
    <joint name="joint_propeller_4" type="revolute">
      <parent>corpo</parent><child>back_right_propeller</child>
      <axis><xyz>0 1 0</xyz><limit><effort>1.485</effort><velocity>602</velocity><lower>-1e16</lower><upper>1e16</upper></limit><dynamics><damping>0.004</damping></dynamics><use_parent_model_frame>1</use_parent_model_frame></axis>
    </joint>
    <joint name="joint_pusher" type="revolute">
      <parent>corpo</parent><child>pusher_propeller</child>
      <axis><xyz>0 1 0</xyz><limit><effort>2.04</effort><velocity>754</velocity><lower>-1e16</lower><upper>1e16</upper></limit><dynamics><damping>0.004</damping></dynamics><use_parent_model_frame>1</use_parent_model_frame></axis>
    </joint>
    <joint name="gimbal_joint" type="revolute">
      <parent>corpo</parent><child>gimbal_link</child>
      <axis><limit><lower>0</lower><upper>0</upper></limit><xyz>0 1 0</xyz></axis>
    </joint>


