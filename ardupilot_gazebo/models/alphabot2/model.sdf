<?xml version="1.0"?>
<sdf version="1.9">

  <model name="alphabot">
    <static>false</static>

    <!-- BASE LINK (CHASSIS)                                    -->

    <link name="base_link">
      <pose>0 0 0.033 0 0 0</pose>

      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.002</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.002</iyy>
          <iyz>0</iyz>
          <izz>0.004</izz>
        </inertia>
      </inertial>

      <collision name="collision">
        <geometry>
          <box>
            <size>0.10 0.09 0.03</size>
          </box>
        </geometry>
      </collision>

      <visual name="visual">
        <geometry>
          <box>
            <size>0.10 0.09 0.03</size>
          </box>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.8 1</ambient>
          <diffuse>0.2 0.2 0.8 1</diffuse>
        </material>
      </visual>
    </link>


   
    <!-- WHEELS  -->
   
    <!-- Left Wheel -->
    <link name="wheel_left_link">
      <inertial>
        <pose>0.0 0.05 0.0 -1.5708 0 0</pose>
        <mass>2.8498940e-02</mass>
        <inertia>
          <ixx>1.8158194e-04</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>3.2922126e-04</iyy>
          <iyz>0</iyz>
          <izz>1.8158194e-04</izz>
        </inertia>
      </inertial>

      <collision name="wheel_left_collision">
        <pose>0.0 0.05 0.0 -1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.033</radius>
            <length>0.018</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
              <fdir1>1 0 0</fdir1>
              <slip1>0.0</slip1>
              <slip2>0.0</slip2>
            </ode>
          </friction>
          <contact>
            <ode>
              <soft_cfm>0</soft_cfm>
              <soft_erp>0.2</soft_erp>
              <kp>1e+5</kp>
              <kd>1</kd>
              <max_vel>0.01</max_vel>
              <min_depth>0.001</min_depth>
            </ode>
          </contact>
        </surface>
      </collision>

      <visual name="wheel_left_visual">
        <pose>0.0 0.05 0.0 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>model://alphabot2/meshes/left_tire.stl</uri>
            <scale>0.001 0.001 0.001</scale>
          </mesh>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.2 1.0</ambient>
          <diffuse>0.2 0.2 0.2 1.0</diffuse>
        </material>
      </visual>
    </link>

    <joint name="left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>wheel_left_link</child>
      <pose>0 0 0 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
        <dynamics>
          <damping>0.001</damping>
          <friction>0.001</friction>
        </dynamics>
      </axis>
    </joint>


    <!-- Right Wheel -->
    <link name="wheel_right_link">
      <inertial>
        <pose>0.0 -0.05 0.0 -1.5708 0 0</pose>
        <mass>2.8498940e-02</mass>
        <inertia>
          <ixx>1.8158194e-04</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>3.2922126e-04</iyy>
          <iyz>0</iyz>
          <izz>1.8158194e-04</izz>
        </inertia>
      </inertial>

      <collision name="wheel_right_collision">
        <pose>0.0 -0.05 0.0 -1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.033</radius>
            <length>0.018</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
              <fdir1>1 0 0</fdir1>
              <slip1>0.0</slip1>
              <slip2>0.0</slip2>
            </ode>
          </friction>
          <contact>
            <ode>
              <soft_cfm>0</soft_cfm>
              <soft_erp>0.2</soft_erp>
              <kp>1e+5</kp>
              <kd>1</kd>
              <max_vel>0.01</max_vel>
              <min_depth>0.001</min_depth>
            </ode>
          </contact>
        </surface>
      </collision>

      <visual name="wheel_right_visual">
        <pose>0.0 -0.05 0.0 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>model://alphabot2/meshes/right_tire.stl</uri>
            <scale>0.001 0.001 0.001</scale>
          </mesh>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.2 1.0</ambient>
          <diffuse>0.2 0.2 0.2 1.0</diffuse>
        </material>
      </visual>
    </link>

    <joint name="right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>wheel_right_link</child>
      <pose>0 0 0 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
        <dynamics>
          <damping>0.001</damping>
          <friction>0.001</friction>
        </dynamics>
      </axis>
    </joint>


  
    <!-- CASTER WHEEL                                           -->
    <link name="caster_link">
      <pose>0.04 0 -0.023 0 0 0</pose>

      <inertial>
        <mass>0.01</mass>
        <inertia>
          <ixx>1e-6</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>1e-6</iyy>
          <iyz>0</iyz>
          <izz>1e-6</izz>
        </inertia>
      </inertial>

      <collision name="caster_collision">
        <geometry>
          <sphere>
            <radius>0.01</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.0</mu>
              <mu2>0.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="caster_visual">
        <geometry>
          <sphere>
            <radius>0.01</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.6 0.6 0.6 1</ambient>
          <diffuse>0.6 0.6 0.6 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="caster_joint" type="ball">
      <parent>base_link</parent>
      <child>caster_link</child>
    </joint>


     <link name="caster_rear_link">
      <pose>-0.04 0 -0.023 0 0 0</pose>

      <inertial>
        <mass>0.01</mass>
        <inertia>
          <ixx>1e-6</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>1e-6</iyy>
          <iyz>0</iyz>
          <izz>1e-6</izz>
        </inertia>
      </inertial>

      <collision name="caster_rear_collision">
        <geometry>
          <sphere>
            <radius>0.01</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.0</mu>
              <mu2>0.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="caster_rear_visual">
        <geometry>
          <sphere>
            <radius>0.01</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.6 0.6 0.6 1</ambient>
          <diffuse>0.6 0.6 0.6 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="caster_rear_joint" type="ball">
      <parent>base_link</parent>
      <child>caster_rear_link</child>
    </joint>

    <!-- DIFFERENTIAL DRIVE PLUGIN                              -->    
    <plugin
      filename="gz-sim-diff-drive-system"
      name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.10</wheel_separation>
      <wheel_radius>0.033</wheel_radius>
      <max_linear_velocity>1.0</max_linear_velocity>
      <max_angular_velocity>2.0</max_angular_velocity>
      <publish_rate>20</publish_rate>
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <frame_id>base_link</frame_id>
      <odom_frame_id>odom</odom_frame_id>
    </plugin>


  
    <!-- FRONT CAMERA                                           -->
    <link name="camera_link">
      <pose>0 0 0.1 0 0 0</pose>

      <inertial>
        <mass>0.001</mass>
        <inertia>
          <ixx>1e-6</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>1e-6</iyy><iyz>0</iyz>
          <izz>1e-6</izz>
        </inertia>
      </inertial>

      <visual name="camera_visual">
        <geometry>
          <box><size>0.01 0.02 0.01</size></box>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>

      <sensor name="front_camera" type="camera">
        <always_on>true</always_on>
        <update_rate>30</update_rate>
        <camera>
          <horizontal_fov>1.05</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.01</near>
            <far>10.0</far>
          </clip>
        </camera>
        <topic>/camera/image_raw</topic>
      </sensor>
    </link>

    <joint name="camera_joint" type="fixed">
      <parent>base_link</parent>
      <child>camera_link</child>
    </joint>


    <!-- IR OBSTACLE SENSORS                                    -->

    <!-- Left IR -->
    <link name="ir_left_link">
      <pose>0.052 0.032 0.03 0 0 0</pose>

      <inertial>
        <mass>0.001</mass>
        <inertia>
          <ixx>1e-6</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>1e-6</iyy><iyz>0</iyz>
          <izz>1e-6</izz>
        </inertia>
      </inertial>

        <collision name="ir_left_collision">
          <geometry>
            <box><size>0.005 0.005 0.005</size></box>
          </geometry>
        </collision>

      <visual name="ir_left_visual">
        <geometry>
          <box><size>0.005 0.005 0.005</size></box>
        </geometry>
        <material>
          <ambient>0.8 0.1 0.1 1</ambient>
          <diffuse>0.8 0.1 0.1 1</diffuse>
        </material>
      </visual>

      <sensor name="ir_left" type="gpu_lidar">
        <always_on>true</always_on>
        <update_rate>20</update_rate>
        <lidar>
          <scan>
            <horizontal>
              <samples>10</samples>
              <resolution>1</resolution>
              <min_angle>-0.2618</min_angle>  <!-- -15 degrees -->
              <max_angle>0.2618</max_angle>   <!-- +15 degrees -->
            </horizontal>
          </scan>
          <range>
            <min>0.02</min>
            <max>0.4</max>
            <resolution>0.01</resolution>
          </range>
        </lidar>
        <topic>/ir/left</topic>
      </sensor>
    </link>

    <joint name="ir_left_joint" type="fixed">
      <parent>base_link</parent>
      <child>ir_left_link</child>
    </joint>


    <!-- Right IR -->
    <link name="ir_right_link">
     <pose>0.052 -0.032 0.03 0 0 0</pose>

      <inertial>
        <mass>0.001</mass>
        <inertia>
          <ixx>1e-6</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>1e-6</iyy><iyz>0</iyz>
          <izz>1e-6</izz>
        </inertia>
      </inertial>

       <collision name="ir_right_collision">
          <geometry>
            <box><size>0.005 0.005 0.005</size></box>
          </geometry>
        </collision>

      <visual name="ir_right_visual">
        <geometry>
          <box><size>0.005 0.005 0.005</size></box>
        </geometry>
        <material>
          <ambient>0.8 0.1 0.1 1</ambient>
          <diffuse>0.8 0.1 0.1 1</diffuse>
        </material>
      </visual>

      <sensor name="ir_right" type="gpu_lidar">
        <always_on>true</always_on>
        <update_rate>20</update_rate>
        <lidar>
          <scan>
            <horizontal>
              <samples>10</samples>
              <resolution>1</resolution>
              <min_angle>-0.2618</min_angle>  <!-- -15 degrees -->
              <max_angle>0.2618</max_angle>   <!-- +15 degrees -->
            </horizontal>
          </scan>
          <range>
            <min>0.02</min>
            <max>0.4</max>
            <resolution>0.01</resolution>
          </range>
        </lidar>
        <topic>/ir/right</topic>
      </sensor>
    </link>

    <joint name="ir_right_joint" type="fixed">
      <parent>base_link</parent>
      <child>ir_right_link</child>
    </joint>


    <!-- LINE TRACKING SENSORS                                  -->

    <!-- Center line sensor -->
    <link name="line_center_link">
      <pose>0.025 0 0.0153 1.5708 0 0</pose>

      <inertial>
        <mass>0.001</mass>
        <inertia>
          <ixx>1e-6</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>1e-6</iyy><iyz>0</iyz>
          <izz>1e-6</izz>
        </inertia>
      </inertial>
      
       <visual name="line_center_link_visual">
        <geometry>
          <box><size>0.005 0.005 0.005</size></box>
        </geometry>
        <material>
          <ambient>0.8 0.1 0.1 1</ambient>
          <diffuse>0.8 0.1 0.1 1</diffuse>
        </material>
      </visual> 

      <sensor name="line_center" type="camera">
        <always_on>true</always_on>
        <update_rate>50</update_rate>
        <camera>
          <horizontal_fov>0.1</horizontal_fov>
          <image>
            <width>32</width>
            <height>32</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.005</near>
            <far>0.1</far>
          </clip>
        </camera>
        <topic>/line/center</topic>
      </sensor>
    </link>

    <joint name="line_center_joint" type="fixed">
      <parent>base_link</parent>
      <child>line_center_link</child>
    </joint>


    <!-- Left line sensor -->
    <link name="line_left_link">
      <pose>0.025 0.015 0.0153 1.5708 0 0</pose>

      <inertial>
        <mass>0.001</mass>
        <inertia>
          <ixx>1e-6</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>1e-6</iyy><iyz>0</iyz>
          <izz>1e-6</izz>
        </inertia>
      </inertial>

       <visual name="line_left_link_visual">
        <geometry>
          <box><size>0.005 0.005 0.005</size></box>
        </geometry>
        <material>
          <ambient>0.8 0.1 0.1 1</ambient>
          <diffuse>0.8 0.1 0.1 1</diffuse>
        </material>
      </visual> 

      <sensor name="line_left" type="camera">
        <always_on>true</always_on>
        <update_rate>50</update_rate>
        <camera>
          <horizontal_fov>0.1</horizontal_fov>
          <image>
            <width>32</width>
            <height>32</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.005</near>
            <far>0.1</far>
          </clip>
        </camera>
        <topic>/line/left</topic>
      </sensor>
    </link>

    <joint name="line_left_joint" type="fixed">
      <parent>base_link</parent>
      <child>line_left_link</child>
    </joint>


    <!-- Right line sensor -->
    <link name="line_right_link">
      <pose>0.025 -0.015 0.0153 1.5708 0 0</pose>

      <inertial>
        <mass>0.001</mass>
        <inertia>
          <ixx>1e-6</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>1e-6</iyy><iyz>0</iyz>
          <izz>1e-6</izz>
        </inertia>
      </inertial>

       <visual name="line_right_link_visual">
        <geometry>
          <box><size>0.005 0.005 0.005</size></box>
        </geometry>
        <material>
          <ambient>0.8 0.1 0.1 1</ambient>
          <diffuse>0.8 0.1 0.1 1</diffuse>
        </material>
      </visual> 

      <sensor name="line_right" type="camera">
        <always_on>true</always_on>
        <update_rate>50</update_rate>
        <camera>
          <horizontal_fov>0.1</horizontal_fov>
          <image>
            <width>32</width>
            <height>32</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.005</near>
            <far>0.1</far>
          </clip>
        </camera>
        <topic>/line/right</topic>
      </sensor>
    </link>

    <joint name="line_right_joint" type="fixed">
      <parent>base_link</parent>
      <child>line_right_link</child>
    </joint>

    <plugin
      filename="gz-sim-joint-state-publisher-system"
      name="gz::sim::systems::JointStatePublisher">
    </plugin>

    <plugin
      filename="gz-sim-odometry-publisher-system"
      name="gz::sim::systems::OdometryPublisher">
      <odom_frame>odom</odom_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <dimensions>3</dimensions>
    </plugin>

  </model>
</sdf>
