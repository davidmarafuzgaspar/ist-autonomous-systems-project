          </material>
        </visual>
        <sensor name="line_sensor_1" type="camera">
          <always_on>true</always_on>
          <update_rate>20</update_rate>
          <visualize>false</visualize>
          <topic>/alphabot2/sensors/line_1/image</topic>
          <camera>
            <horizontal_fov>0.20</horizontal_fov>
            <image>
              <width>1</width>
              <height>1</height>
              <format>R8G8B8</format>
            </image>
            <clip>
              <near>0.001</near>
              <far>0.10</far>
            </clip>
          </camera>
        </sensor>
      </link>

