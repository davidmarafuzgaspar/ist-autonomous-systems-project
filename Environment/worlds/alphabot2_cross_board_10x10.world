        <sensor name="right_obstacle_sensor" type="lidar">
          <always_on>true</always_on>
          <update_rate>20</update_rate>
          <visualize>true</visualize>
          <topic>/alphabot2/sensors/obstacle_right/range</topic>
          <lidar>
            <scan>
              <horizontal>
                <samples>1</samples>
                <resolution>1</resolution>
                <min_angle>0</min_angle>
                <max_angle>0</max_angle>
              </horizontal>
              <vertical>
                <samples>1</samples>
                <resolution>1</resolution>
                <min_angle>0</min_angle>
                <max_angle>0</max_angle>
              </vertical>
            </scan>
            <range>
              <min>0.01</min>
              <max>0.07</max>
              <resolution>0.001</resolution>
            </range>
          </lidar>
        </sensor>
      </link>

      <link name="line_sensor_1_link">
        <pose>0.055 0.040 0.005 0 1.5708 0</pose>
        <inertial>
          <mass>0.001</mass>
          <inertia>
            <ixx>0.000001</ixx>
