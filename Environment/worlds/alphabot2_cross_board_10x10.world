    <!--
      AlphaBot2 simplified simulation model
      - chassis diameter = 0.15 m
      - 2 front obstacle sensors with 0.07 m max range
      - 5 bottom line sensors placed 0.02 m from the front edge
      - line sensor spacing = 0.02 m
    -->
    <model name="alphabot2">
      <pose>0 0 0.01 0 0 0</pose>
      <self_collide>false</self_collide>
      <allow_auto_disable>false</allow_auto_disable>

      <link name="chassis_link">
        <inertial>
          <mass>0.50</mass>
          <inertia>
            <ixx>0.00072</ixx>
            <iyy>0.00072</iyy>
            <izz>0.00141</izz>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyz>0</iyz>
          </inertia>
        </inertial>

        <collision name="chassis_collision">
          <pose>0 0 0.015 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.075</radius>
              <length>0.02</length>
            </cylinder>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>1.0</mu>
                <mu2>1.0</mu2>
              </ode>
            </friction>
          </surface>
        </collision>

        <visual name="chassis_visual">
          <pose>0 0 0.025 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.075</radius>
              <length>0.04</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.15 0.55 0.15 1</ambient>
            <diffuse>0.15 0.55 0.15 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>

        <visual name="front_marker_visual">
          <pose>0.055 0 0.045 0 0 0</pose>
          <geometry>
            <box>
              <size>0.025 0.06 0.005</size>
            </box>
          </geometry>
          <material>
            <ambient>0.9 0.9 0.9 1</ambient>
            <diffuse>0.9 0.9 0.9 1</diffuse>
          </material>
        </visual>

        <visual name="left_wheel_visual">
          <pose>0 0.078 0.03 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.03</radius>
              <length>0.01</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.05 0.05 0.05 1</ambient>
            <diffuse>0.05 0.05 0.05 1</diffuse>
          </material>
        </visual>

        <visual name="right_wheel_visual">
          <pose>0 -0.078 0.03 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.03</radius>
              <length>0.01</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.05 0.05 0.05 1</ambient>
            <diffuse>0.05 0.05 0.05 1</diffuse>
          </material>
        </visual>

        <visual name="rear_caster_visual">
          <pose>-0.045 0 0.01 0 0 0</pose>
          <geometry>
            <sphere>
              <radius>0.01</radius>
            </sphere>
          </geometry>
          <material>
            <ambient>0.6 0.6 0.6 1</ambient>
            <diffuse>0.6 0.6 0.6 1</diffuse>
          </material>
        </visual>
      </link>

      <link name="left_obstacle_sensor_link">
        <pose>0.067 0.028 0.025 0 0 0</pose>
        <inertial>
          <mass>0.001</mass>
          <inertia>
            <ixx>0.000001</ixx>
            <iyy>0.000001</iyy>
            <izz>0.000001</izz>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyz>0</iyz>
          </inertia>
        </inertial>
        <visual name="left_obstacle_sensor_visual">
          <geometry>
            <box>
              <size>0.008 0.008 0.008</size>
            </box>
          </geometry>
          <material>
            <ambient>0.8 0.2 0.2 1</ambient>
            <diffuse>0.8 0.2 0.2 1</diffuse>
          </material>
        </visual>
        <sensor name="left_obstacle_sensor" type="lidar">
          <always_on>true</always_on>
          <update_rate>20</update_rate>
          <visualize>true</visualize>
          <topic>/alphabot2/sensors/obstacle_left/range</topic>
          <lidar>
            <scan>
              <horizontal>
                <samples>1</samples>
                <resolution>1</resolution>
                <min_angle>0</min_angle>
                <max_angle>0</max_angle>
              </horizontal>
              <vertical>
                <samples>1</samples>
                <resolution>1</resolution>
                <min_angle>0</min_angle>
                <max_angle>0</max_angle>
              </vertical>
            </scan>
            <range>
              <min>0.01</min>
              <max>0.07</max>
              <resolution>0.001</resolution>
            </range>
          </lidar>
        </sensor>
      </link>

      <link name="right_obstacle_sensor_link">
        <pose>0.067 -0.028 0.025 0 0 0</pose>
        <inertial>
          <mass>0.001</mass>
          <inertia>
            <ixx>0.000001</ixx>
            <iyy>0.000001</iyy>
            <izz>0.000001</izz>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyz>0</iyz>
          </inertia>
        </inertial>
        <visual name="right_obstacle_sensor_visual">
          <geometry>
            <box>
              <size>0.008 0.008 0.008</size>
